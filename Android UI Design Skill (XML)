Loading State
Every screen must have a loading state. Never show a blank screen or a spinner with no context.

<!-- Shimmer loading skeleton (recommended over spinner for content screens) -->
<com.facebook.shimmer.ShimmerFrameLayout
    android:id="@+id/shimmerLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:visibility="visible"
    tools:visibility="gone">
    <!-- Repeat placeholder items to match expected content shape -->
    <include layout="@layout/skeleton_[item_type]" />
    <include layout="@layout/skeleton_[item_type]" />
    <include layout="@layout/skeleton_[item_type]" />
</com.facebook.shimmer.ShimmerFrameLayout>
<!-- Skeleton item template: res/layout/skeleton_[name].xml -->
<View
    android:layout_width="match_parent"
    android:layout_height="16dp"
    android:layout_margin="@dimen/spacing_16"
    android:background="@drawable/bg_skeleton_placeholder" />

