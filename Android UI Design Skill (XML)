Primary button (filled): com.google.android.material.button.MaterialButton style="@style/Widget.Material3.Button"

Secondary button (outlined): com.google.android.material.button.MaterialButton style="@style/Widget.Material3.Button.OutlinedButton"

Tertiary button (text): com.google.android.material.button.MaterialButton style="@style/Widget.Material3.Button.TextButton"

