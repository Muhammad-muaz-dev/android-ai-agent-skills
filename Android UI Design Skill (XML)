Screens (Activity or Fragment) fragment_[feature_name].xml / activity_[name].xml RecyclerView items item_[entity_name].xml Dialog layouts dialog_[name].xml Bottom sheet layouts bottom_sheet_[name].xml Custom view layouts view_[component_name].xml Reusable partial layouts layout_[component_name].xml Skeleton loaders skeleton_[entity_name].xml

