</com.google.android.material.appbar.CollapsingToolbarLayout>

Material Card
<com.google.android.material.card.MaterialCardView
    android:id="@+id/card[Name]"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/spacing_8"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="@dimen/radius_large"
    app:cardElevation="@dimen/elevation_card"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    app:rippleColor="?attr/colorPrimary">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_16">
        <!-- Card content -->
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

Card variants:

app:cardElevation="0dp" + app:strokeWidth="1dp" → Outlined card
app:cardElevation="@dimen/elevation_card" + no stroke → Elevated card
app:cardBackgroundColor="?attr/colorPrimaryContainer" → Filled/tonal card
Text Input Field
<com.google.android.material.textfield.TextInputLayout
    android:id="@+id/til[FieldName]"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:hint="@string/hint_[field_name]"
    app:helperText="@string/helper_[field_name]"
    app:errorEnabled="true"
    app:startIconDrawable="@drawable/ic_[icon]_24"
    app:startIconContentDescription="@string/cd_[icon]"
    app:endIconMode="clear_text"
    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/et[FieldName]"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:imeOptions="actionNext"
        android:maxLines="1"
        android:importantForAutofill="yes"
        android:autofillHints="[autofillHintConstant]" />
</com.google.android.material.textfield.TextInputLayout>

TextInputLayout style variants:

@style/Widget.Material3.TextInputLayout.OutlinedBox — bordered
@style/Widget.Material3.TextInputLayout.FilledBox — filled with underline
@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense — compact height
